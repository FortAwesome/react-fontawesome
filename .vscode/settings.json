{
  // VSCode Core Settings
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "js/ts.format.enabled": false, // formatting is handled by prettier
  "js/ts.validate.enabled": false, // validation is handled by typescript and eslint
  "js/ts.tsdk.path": "node_modules/typescript/lib", // ensure VSCode uses the local TypeScript version
  // Language-specific Overrides
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[svg]": {
    "editor.defaultFormatter": "jock.svg"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // Extension Settings
  "eslint.enable": true,
  "eslint.format.enable": false, // formatting is handled by prettier
  "eslint.runtime": "/Users/charles.harwood/.local/share/mise/installs/node/22.22.2/bin/node",
  "prettier.enable": true,
  "jest.shell": "zsh"
}
